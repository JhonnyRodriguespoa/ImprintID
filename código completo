} from "@metaplex-foundation/umi";
import { base58 } from "@metaplex-foundation/umi/serializers";
import { logger } from "./logger";
const RPC_URL = process.env["VITE_SOLANA_RPC"] ?? "https://api.devnet.solana.com";
const MEMO_PROGRAM_ID = new PublicKey("MemoSq4gqABAXKb96qnH8TysNcWxMyWCqXgDLGmfcHr");
// ── Server payer keypair ──────────────────────────────────────────────────────
// Priority:
//   1. SOLANA_SERVER_KEYPAIR (JSON array of 64 ints) — explicit override
//   2. SESSION_SECRET → SHA-256 seed               — stable across restarts
//   3. Ephemeral (random)                           — last resort, logs warning
let _payerKeypair: Keypair | null = null;
export function getPayerKeypair(): Keypair {
  if (_payerKeypair) return _payerKeypair;
  const raw = process.env["SOLANA_SERVER_KEYPAIR"];
  if (raw) {
    try {
      _payerKeypair = Keypair.fromSecretKey(new Uint8Array(JSON.parse(raw) as number[]));
      logger.info({ pubkey: _payerKeypair.publicKey.toBase58() }, "Server payer loaded from SOLANA_SERVER_KEYPAIR");
      return _payerKeypair;
    } catch {
      logger.warn("SOLANA_SERVER_KEYPAIR parse failed — falling through to SESSION_SECRET derivation");
    }
  }
  const session = process.env["SESSION_SECRET"];
  if (session) {
    const seed = crypto.createHash("sha256").update(`imprintid-solana-payer:${session}`).digest();
    _payerKeypair = Keypair.fromSeed(new Uint8Array(seed));
    logger.info({ pubkey: _payerKeypair.publicKey.toBase58() }, "Server payer derived from SESSION_SECRET (stable across restarts)");
    return _payerKeypair;
  }
  _payerKeypair = Keypair.generate();
  logger.warn({ pubkey: _payerKeypair.publicKey.toBase58() }, "Ephemeral keypair — fund at https://faucet.solana.com");
  return _payerKeypair;
}
export async function getServerWalletInfo(): Promise<{ pubkey: string; balanceSOL: number; needsFunding: boolean }> {
  const keypair = getPayerKeypair();
  const conn = new Connection(RPC_URL, "confirmed");
  try {
    const balance = await conn.getBalance(keypair.publicKey);
    const balanceSOL = balance / LAMPORTS_PER_SOL;
    return { pubkey: keypair.publicKey.toBase58(), balanceSOL, needsFunding: balanceSOL < 0.1 };
  } catch {
    return { pubkey: keypair.publicKey.toBase58(), balanceSOL: -1, needsFunding: true };
  }
}
export async function ensureServerWalletFunded(): Promise<void> {
  const keypair = getPayerKeypair();
  const conn = new Connection(RPC_URL, "confirmed");
  try {
    const balance = await conn.getBalance(keypair.publicKey);
    const sol = balance / LAMPORTS_PER_SOL;
    logger.info({ pubkey: keypair.publicKey.toBase58(), balanceSOL: sol }, "Server wallet balance");
    if (balance < 0.3 * LAMPORTS_PER_SOL) {
      logger.info("Server wallet low — requesting airdrop");
      for (let i = 0; i < 2; i++) {
        try {
          const sig = await conn.requestAirdrop(keypair.publicKey, 2 * LAMPORTS_PER_SOL);
          const { blockhash, lastValidBlockHeight } = await conn.getLatestBlockhash();
          await conn.confirmTransaction({ signature: sig, blockhash, lastValidBlockHeight }, "confirmed");
          logger.info({ sig, attempt: i + 1 }, "Server wallet airdropped 2 SOL");
          return;
        } catch (err) {
          logger.warn({ err, attempt: i + 1 }, `Airdrop attempt ${i + 1} failed`);
          if (i < 1) await new Promise((r) => setTimeout(r, 3000));
        }
      }
    }
  } catch (err) {
    logger.warn({ err }, "Server wallet auto-fund failed. Fund manually at https://faucet.solana.com");
  }
}
export interface AnchorPayload {
  hash: string; uri: string; iss: number;
  attachmentProfile: string; variant: string;
  timestamp: number; walletAddress: string;
}
export async function createServerMemoTx(payload: AnchorPayload): Promise<string> {
  const payer = getPayerKeypair();
  const conn = new Connection(RPC_URL, "confirmed");
  const memoData = JSON.stringify({
    p: "imprint-v2", h: payload.hash, u: payload.uri,
    iss: payload.iss, ap: payload.attachmentProfile, v: payload.variant,
    t: payload.timestamp, w: payload.walletAddress,
  });
  const memoInstruction = new TransactionInstruction({
    keys: [{ pubkey: payer.publicKey, isSigner: true, isWritable: false }],
    programId: MEMO_PROGRAM_ID,
    data: Buffer.from(memoData, "utf-8"),
  });
  const { blockhash, lastValidBlockHeight } = await conn.getLatestBlockhash("confirmed");
  const tx = new Transaction().add(memoInstruction);
  tx.recentBlockhash = blockhash;
  tx.feePayer = payer.publicKey;
  tx.sign(payer);
  const signature = await conn.sendRawTransaction(tx.serialize());
  await conn.confirmTransaction({ signature, blockhash, lastValidBlockHeight }, "confirmed");
  return signature;
}
export interface ServerMintResult { mint: string; txSignature: string; }
export async function mintNftForWallet(
  recipientAddress: string,
  metadataUri: string,
  nftName: string
): Promise<ServerMintResult> {
  const payer = getPayerKeypair();
  const umi = createUmi(RPC_URL).use(mplTokenMetadata());
  const umiKeypair = umi.eddsa.createKeypairFromSecretKey(payer.secretKey);
  umi.use(keypairIdentity(createSignerFromKeypair(umi, umiKeypair)));
  const mint = generateSigner(umi);
  const { signature } = await createNft(umi, {
    mint,
    name: nftName,
    symbol: "IMPRINT",
    uri: metadataUri,
    sellerFeeBasisPoints: percentAmount(0),
    isMutable: false,
    tokenOwner: umiPublicKey(recipientAddress),
  }).sendAndConfirm(umi, { confirm: { commitment: "confirmed" } });
  const [txSignature] = base58.deserialize(new Uint8Array(signature));
  return { mint: mint.publicKey.toString(), txSignature };
}

