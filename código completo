import { useState, useMemo } from "react";
import { QueryClient, QueryClientProvider } from "@tanstack/react-query";
import { ConnectionProvider, WalletProvider, useWallet } from "@solana/wallet-adapter-react";
import { WalletModalProvider } from "@solana/wallet-adapter-react-ui";
import { PhantomWalletAdapter } from "@solana/wallet-adapter-wallets";
import "@solana/wallet-adapter-react-ui/styles.css";
import Connect from "./pages/Connect";
import Landing from "./pages/Landing";
import Experiment, { type FullExperimentResult } from "./pages/Experiment";
import Dashboard from "./pages/Dashboard";
const queryClient = new QueryClient();
type Page = "landing" | "connect" | "experiment" | "dashboard";
function AppContent() {
  const { connected } = useWallet();
  const [page, setPage] = useState<Page>("landing");
  const [result, setResult] = useState<FullExperimentResult | null>(() => {
    try {
      const stored = localStorage.getItem("imprint_last_result");
      return stored ? (JSON.parse(stored) as FullExperimentResult) : null;
    } catch {
      return null;
    }
  });
  function handleFinish(data: FullExperimentResult) {
    setResult(data);
    try { localStorage.setItem("imprint_last_result", JSON.stringify(data)); } catch {}
    setPage("dashboard");
  }
  function goToExperiment() {
    if (!connected) { setPage("connect"); return; }
    setPage("experiment");
  }
  function goToDashboard() {
    if (!connected) { setPage("connect"); return; }
    setPage("dashboard");
  }
  if (page === "connect") {
    return <Connect onConnected={() => setPage("experiment")} />;
  }
  if (page === "landing") {
    return (
      <Landing
        goExperiment={goToExperiment}
        goDashboard={goToDashboard}
      />
    );
  }
  if (page === "experiment") {
    return (
      <Experiment
        onFinish={handleFinish}
        goBack={() => setPage("landing")}
      />
    );
  }
  return (
    <Dashboard
      result={result}
      goBack={() => setPage("landing")}
      goExperiment={goToExperiment}
    />
  );
}
export default function App() {
  const wallets = useMemo(
    () => [new PhantomWalletAdapter()],
    []
  );
  return (
    <QueryClientProvider client={queryClient}>
      <ConnectionProvider endpoint={import.meta.env.VITE_SOLANA_RPC ?? "https://api.devnet.solana.com"}>
        <WalletProvider wallets={wallets} autoConnect>
          <WalletModalProvider>
            <AppContent />
          </WalletModalProvider>
        </WalletProvider>
      </ConnectionProvider>
    </QueryClientProvider>
  );
}

