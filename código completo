async function uploadJson(data: object, filename: string): Promise<string> {
  const key = import.meta.env.VITE_WEB3_STORAGE_KEY;
  if (!key) {
    // Mock fallback when key is not configured
    await new Promise((r) => setTimeout(r, 400));
    return `ipfs://bafybei${Math.random().toString(36).slice(2, 14)}/${filename}`;
  }
  const blob = new Blob([JSON.stringify(data)], { type: "application/json" });
  const file = new File([blob], filename);
  const formData = new FormData();
  formData.append("file", file);
  const res = await fetch("https://api.web3.storage/upload", {
    method: "POST",
    headers: { Authorization: `Bearer ${key}` },
    body: formData,
  });
  if (!res.ok) throw new Error(`IPFS upload failed: ${res.statusText}`);
  const json = await res.json();
  return `https://${json.cid}.ipfs.dweb.link/${filename}`;
}
