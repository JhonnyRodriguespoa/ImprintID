use anchor_lang::prelude::*;
declare_id!("REPLACE_WITH_YOUR_PROGRAM_ID");
// Space: 8 (discriminator) + 32 (owner) + 68 (hash) + 104 (uri) + 1 (iss)
//        + 20 (attachment_profile) + 6 (variant) + 8 (timestamp) + 1 (bump) = 248
const IMPRINT_SPACE: usize = 8 + 32 + (4 + 64) + (4 + 100) + 1 + (4 + 16) + (4 + 2) + 8 + 1;
#[program]
pub mod imprintid {
    use super::*;
    /// Create a single behavioral-identity record anchored to the signer's wallet.
    /// PDA: seeds = ["imprint", owner_pubkey] — one account per wallet.
    pub fn create_imprint(
        ctx: Context<CreateImprint>,
        hash: String,
        uri: String,
        iss: u8,
        attachment_profile: String,
        variant: String,
    ) -> Result<()> {
        require!(hash.len() <= 64,              ImprintError::HashTooLong);
        require!(uri.len() <= 100,              ImprintError::UriTooLong);
        require!(iss <= 100,                    ImprintError::IssOutOfRange);
        require!(attachment_profile.len() <= 16,ImprintError::ProfileTooLong);
        require!(variant.len() <= 2,            ImprintError::VariantTooLong);
        let imprint = &mut ctx.accounts.imprint;
        imprint.owner             = ctx.accounts.owner.key();
        imprint.hash              = hash;
        imprint.uri               = uri;
        imprint.iss               = iss;
        imprint.attachment_profile = attachment_profile;
        imprint.variant           = variant;
        imprint.timestamp         = Clock::get()?.unix_timestamp;
        imprint.bump              = ctx.bumps.imprint;
        msg!("ImprintID: owner={} iss={} profile={} hash={}",
            imprint.owner, imprint.iss, imprint.attachment_profile,
            &imprint.hash[..8.min(imprint.hash.len())]);
        Ok(())
    }
}
#[derive(Accounts)]
pub struct CreateImprint<'info> {
    #[account(
        init,
        payer = owner,
        space = IMPRINT_SPACE,
        seeds = [b"imprint", owner.key().as_ref()],
        bump,
    )]
    pub imprint: Account<'info, Imprint>,
    #[account(mut)]
    pub owner: Signer<'info>,
    pub system_program: Program<'info, System>,
}
