import { useState, useRef, useEffect } from "react";
import { useWallet, useConnection } from "@solana/wallet-adapter-react";
import { Copy, CheckCheck, ExternalLink, LogOut, ChevronDown, Droplets } from "lucide-react";
import { motion, AnimatePresence } from "framer-motion";
import * as anchor from "@coral-xyz/anchor";
import { requestAirdrop } from "../lib/solana";
function shortenAddress(addr: string) {
  return addr.slice(0, 4) + "..." + addr.slice(-4);
}
function useSOLBalance(publicKey: anchor.web3.PublicKey | null) {
  const { connection } = useConnection();
  const [balance, setBalance] = useState<number | null>(null);
  useEffect(() => {
    if (!publicKey) { setBalance(null); return; }
    let cancelled = false;
    connection.getBalance(publicKey).then((lamports) => {
      if (!cancelled) setBalance(lamports / anchor.web3.LAMPORTS_PER_SOL);
    }).catch(() => { if (!cancelled) setBalance(null); });
    const id = connection.onAccountChange(publicKey, (info) => {
      if (!cancelled) setBalance(info.lamports / anchor.web3.LAMPORTS_PER_SOL);
    });
    return () => { cancelled = true; connection.removeAccountChangeListener(id); };
  }, [publicKey, connection]);
  return balance;
}
export default function WalletButton() {
  const { connected, connecting, publicKey, disconnect, select, wallets } = useWallet();
  const { connection } = useConnection();
  const balance = useSOLBalance(publicKey);
  const [open, setOpen] = useState(false);
  const [copied, setCopied] = useState(false);
  const [airdropping, setAirdropping] = useState(false);
  const ref = useRef<HTMLDivElement>(null);
  const address = publicKey?.toBase58() ?? "";
  useEffect(() => {
    function handler(e: MouseEvent) {
      if (ref.current && !ref.current.contains(e.target as Node)) setOpen(false);
    }
    document.addEventListener("mousedown", handler);
    return () => document.removeEventListener("mousedown", handler);
  }, []);
  function copyAddress() {
    navigator.clipboard.writeText(address);
    setCopied(true);
    setTimeout(() => setCopied(false), 2000);
  }
  async function handleAirdrop() {
    if (!publicKey) return;
    setAirdropping(true);
    try { await requestAirdrop(connection, publicKey); } catch {}
    setAirdropping(false);
  }
  function connectPhantom() {
    const phantom = wallets.find(w => w.adapter.name === "Phantom");
    if (phantom) {
      select(phantom.adapter.name);
      phantom.adapter.connect().catch(() => {});
    } else {
      window.open("https://phantom.app/", "_blank");
    }
  }
  if (connecting) {
    return (
      <div className="flex items-center gap-2 px-4 py-2 rounded-xl border border-white/10 bg-white/5 text-sm text-white/50">
        <div className="w-3.5 h-3.5 rounded-full border-2 border-violet-400 border-t-transparent animate-spin" />
        Connecting...
      </div>
    );
  }
  if (!connected) {
    return (
      <button onClick={connectPhantom} className="flex items-center gap-2 px-4 py-2 rounded-xl border border-violet-500/30 bg-violet-500/10 hover:bg-violet-500/20 text-violet-300 text-sm font-medium transition-all">
        Connect Phantom
      </button>
    );
  }
  return (
    <div className="relative" ref={ref}>
      <button onClick={() => setOpen((v) => !v)} className="flex items-center gap-2.5 px-3 py-2 rounded-xl border border-white/10 bg-white/5 hover:bg-white/8 transition-all text-sm">
        <span className="font-mono text-white/80">{shortenAddress(address)}</span>
        {balance !== null && (
          <span className="text-white/35 text-xs border-l border-white/10 pl-2.5">
            {balance.toFixed(3)} SOL
          </span>
        )}
        <ChevronDown className={`w-3.5 h-3.5 text-white/30 transition-transform ${open ? "rotate-180" : ""}`} />
      </button>
      <AnimatePresence>
        {open && (
          <motion.div initial={{ opacity: 0, y: 6, scale: 0.97 }} animate={{ opacity: 1, y: 0, scale: 1 }} exit={{ opacity: 0, y: 4, scale: 0.97 }} transition={{ duration: 0.15 }}
            className="absolute right-0 top-full mt-2 w-72 rounded-2xl border border-white/10 bg-[#111] shadow-2xl shadow-black/60 overflow-hidden z-50">
            <div className="px-4 py-4 border-b border-white/8">
              <div onClick={copyAddress} className="flex items-center justify-between px-3 py-2 rounded-xl bg-white/5 border border-white/8 cursor-pointer hover:bg-white/8 transition-colors group">
                <span className="font-mono text-xs text-white/60 tracking-wide">{shortenAddress(address)}</span>
                {copied ? <CheckCheck className="w-3.5 h-3.5 text-emerald-400" /> : <Copy className="w-3.5 h-3.5 text-white/25 group-hover:text-white/50 transition-colors" />}
              </div>
            </div>
            <div className="px-4 py-4 border-b border-white/8">
              <div className="flex items-center justify-between mb-1">
                <p className="text-[10px] font-mono text-white/30 uppercase tracking-widest">Balance · Devnet</p>
                <button onClick={handleAirdrop} disabled={airdropping}
                  className="flex items-center gap-1 text-[10px] font-mono text-blue-400 hover:text-blue-300 transition-colors disabled:opacity-50">
                  <Droplets className="w-3 h-3" />
                  {airdropping ? "Airdropping..." : "Airdrop 1 SOL"}
                </button>
              </div>
              <p className="text-2xl font-bold text-white">{balance !== null ? `${balance.toFixed(4)} SOL` : "—"}</p>
            </div>
            <div className="p-2">
              <a href={`https://solscan.io/account/${address}?cluster=devnet`} target="_blank" rel="noopener noreferrer"
                className="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-white/5 transition-colors text-sm text-white/60 hover:text-white/90 w-full" onClick={() => setOpen(false)}>
                <ExternalLink className="w-4 h-4" /> View on Solscan
              </a>
              <button onClick={() => { disconnect(); setOpen(false); }}
                className="flex items-center gap-3 px-3 py-2.5 rounded-xl hover:bg-red-500/8 transition-colors text-sm text-white/40 hover:text-red-400 w-full">
                <LogOut className="w-4 h-4" /> Disconnect
              </button>
            </div>
          </motion.div>
        )}
      </AnimatePresence>
    </div>
  );
}

