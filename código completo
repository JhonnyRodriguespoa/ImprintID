import { Router } from "express";
import { z } from "zod";
import { mintNftForWallet, createServerMemoTx, getServerWalletInfo } from "../lib/solana-nft";
const router = Router();
const MintBody = z.object({
  walletAddress:     z.string().min(32).max(44),
  metadataUri:       z.string().min(1).max(500),
  nftName:           z.string().min(1).max(100),
  hash:              z.string().max(128).optional(),
  uri:               z.string().max(500).optional(),
  iss:               z.number().int().min(0).max(100).optional(),
  attachmentProfile: z.string().max(32).optional(),
  variant:           z.string().max(4).optional(),
  timestamp:         z.number().optional(),
});
router.post("/nft/mint", async (req, res) => {
  const parsed = MintBody.safeParse(req.body);
  if (!parsed.success) {
    res.status(400).json({ error: "Invalid request", details: parsed.error.flatten() });
    return;
  }
  const { walletAddress, metadataUri, nftName, hash, uri, iss, attachmentProfile, variant, timestamp } = parsed.data;
  // NFT mint (non-fatal)
  let mint: string | undefined;
  let txSignature: string | undefined;
  let nftError: string | undefined;
  try {
    const result = await mintNftForWallet(walletAddress, metadataUri, nftName);
    mint = result.mint;
    txSignature = result.txSignature;
    req.log.info({ mint, txSignature, walletAddress }, "NFT minted");
  } catch (err) {
    nftError = (err as { message?: string })?.message ?? "NFT mint failed";
    req.log.warn({ err, walletAddress }, "NFT mint failed (non-fatal)");
  }
  // Server-side Memo anchor tx (non-fatal)
  let memoSignature: string | undefined;
  let memoError: string | undefined;
  if (hash && uri && iss !== undefined && attachmentProfile && variant && timestamp) {
    try {
      memoSignature = await createServerMemoTx({ hash, uri, iss, attachmentProfile, variant, timestamp, walletAddress });
      req.log.info({ memoSignature, walletAddress }, "Server memo tx anchored");
    } catch (err) {
      memoError = (err as { message?: string })?.message ?? "Memo tx failed";
      req.log.warn({ err, walletAddress }, "Server memo tx failed (non-fatal)");
    }
  }
  const walletInfo = await getServerWalletInfo().catch(() => null);
  // Always 200 — let the frontend handle degradation gracefully
  res.json({
    mint, txSignature, memoSignature,
    ...(nftError && { nftError }),
    ...(memoError && { memoError }),
    serverWallet: walletInfo?.pubkey,
    serverBalanceSOL: walletInfo?.balanceSOL,
  });
});
