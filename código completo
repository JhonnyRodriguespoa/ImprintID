export type ReactionLevel    = "nothing" | "slight" | "emotional" | "strong";
export type AssociationLevel = "yes" | "no" | "prefer_not";
export type AttachmentProfile = "seguro" | "ansioso" | "evitativo" | "desorganizado";
export type ResponseType     = "instinctive" | "reflective";
export interface StimulusResponse {
  id: string;
  label: string;
  variant: "A" | "B";
  reaction: ReactionLevel;
  association: AssociationLevel;
  anxiety: number;        // 0–10
  sadness: number;        // 0–10
  fear: number;           // 0–10
  connection: number;     // 0–10
  reactionTimeMs: number;
  observeTimeMs: number;
  responseType: ResponseType;
}
export interface ISSResult {
  score: number;                    // 0–100
  attachmentProfile: AttachmentProfile;
  attachmentLabel: string;
  attachmentDesc: string;
  attachmentColor: string;
  sensitivity: "high" | "moderate" | "low" | "minimal";
  sensitivityLabel: string;
  emotionalIntensity: number;       // E
  associationRate: number;          // A
  avgObserveTimeMs: number;         // T
  emotionalDelta: number;           // D
  emotionalVariance: number;        // V
  dominantTrigger: string;
  dominantTriggerLabel: string;
  overallResponseType: ResponseType | "mixed";
  breakdown: {
    scaleScore: number;
    associationScore: number;
    reactionBonus: number;
    varianceScore: number;
  };
  perStimulus: { id: string; label: string; intensity: number; contribution: number; variant: "A" | "B" }[];
  profile: AttachmentProfile;
  profileLabel: string;
  profileDesc: string;
}
const REACTION_WEIGHT: Record<ReactionLevel, number> = {
  nothing: 0, slight: 2, emotional: 6, strong: 10,
};
export function computeISS(responses: StimulusResponse[]): ISSResult {
  if (responses.length === 0) return emptyResult();
  const stimData = responses.map((r) => ({
    id: r.id, label: r.label, variant: r.variant,
    intensity: (r.anxiety + r.sadness + r.fear + r.connection) / 4,
  }));
  const intensities = stimData.map((s) => s.intensity);
  const E = intensities.reduce((a, b) => a + b, 0) / intensities.length;
  const A = responses.filter((r) => r.association === "yes").length / responses.length;
  const T = responses.reduce((a, r) => a + r.observeTimeMs, 0) / responses.length;
  const D = Math.max(...intensities) - Math.min(...intensities);
  const V = Math.sqrt(intensities.reduce((s, x) => s + (x - E) ** 2, 0) / intensities.length);
  const dominant = stimData.reduce((a, b) => (a.intensity >= b.intensity ? a : b));
  const instinctiveRatio = responses.filter((r) => r.responseType === "instinctive").length / responses.length;
  const overallResponseType: ResponseType | "mixed" =
    instinctiveRatio > 0.7 ? "instinctive" : instinctiveRatio < 0.3 ? "reflective" : "mixed";
  const scaleScore      = Math.round(E * 5);
  const associationScore = Math.round(A * 20);
  const reactionBonus   = responses.filter(
    (r) => (r.reaction === "emotional" || r.reaction === "strong") && r.observeTimeMs < 8000
  ).length * 3;
  const varianceScore   = Math.round(Math.min(V * 4, 18));
  const score           = Math.min(100, Math.max(0, scaleScore + associationScore + reactionBonus + varianceScore));
  // Attachment profile — Bowlby / Ainsworth
  let attachmentProfile: AttachmentProfile;
  if (E < 3 && A < 0.25) {
    attachmentProfile = "evitativo";
  } else if (V >= 2.5 && D >= 4) {
    attachmentProfile = "desorganizado";
  } else if (E >= 6.5 || (A >= 0.5 && T < 10000)) {
    attachmentProfile = "ansioso";
  } else {
    attachmentProfile = "seguro";
  }
  // ... (profileMap, perStimulus, return — ver repositório completo)
  return { score, attachmentProfile, /* ... */ } as ISSResult;
}

