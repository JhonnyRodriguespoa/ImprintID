import { useState, useRef } from "react";
import { useWallet } from "@solana/wallet-adapter-react";
import { motion, AnimatePresence } from "framer-motion";
import { generateHash } from "../lib/hash";
import { uploadToIPFS, uploadNftMetadata } from "../lib/ipfs";
import { buildNftMetadata } from "../lib/nft";
import {
  ArrowLeft, ArrowRight, Loader2, CheckCircle, AlertCircle, ShieldCheck,
} from "lucide-react";
import WalletButton from "../components/WalletButton";
import StimulusVisual from "../components/StimulusVisual";
import ScaleSlider from "../components/ScaleSlider";
import type { StimulusResponse, ReactionLevel, AssociationLevel, ResponseType } from "../lib/iss";
import { computeISS } from "../lib/iss";
const STIMULI = [
  { id: "flood",        label: "Enchentes RS",              context: "Sul do Brasil, 2024" },
  { id: "covid",        label: "COVID-19",                  context: "Pandemia, 2020–2022" },
  { id: "displacement", label: "Deslocamento Populacional", context: "Crise global de deslocamento" },
  { id: "conflict",     label: "Conflito Geopolítico",      context: "Zona urbana, em curso" },
];
type Step =
  | "consent" | "intro" | "observe" | "react-immediate"
  | "react-association" | "react-scales" | "transition"
  | "processing" | "done" | "error";
interface BlankResponse {
  reaction: ReactionLevel;
  association: AssociationLevel;
  anxiety: number;
  sadness: number;
  fear: number;
  connection: number;
}
function blankResponse(): BlankResponse {
  return { reaction: "nothing", association: "no", anxiety: 0, sadness: 0, fear: 0, connection: 0 };
}
export interface FullExperimentResult {
  hash: string;
  uri: string;
  signature: string;
  responses: StimulusResponse[];
  iss: ReturnType<typeof computeISS>;
  timestamp: number;
  nftMint?: string;
  nftMetadataUri?: string;
  nftTx?: string;
}
interface ExperimentProps {
  onFinish: (result: FullExperimentResult) => void;
  goBack: () => void;
}
export default function Experiment({ onFinish, goBack }: ExperimentProps) {
  const wallet = useWallet();
  const { connected, publicKey } = wallet;
  const [step, setStep] = useState<Step>("consent");
  const [stimIdx, setStimIdx] = useState(0);
  const [responses, setResponses] = useState<StimulusResponse[]>([]);
  const [current, setCurrent] = useState<BlankResponse>(blankResponse());
  const [error, setError] = useState<string | null>(null);
  const [progress, setProgress] = useState("");
  const [countdown, setCountdown] = useState<number | null>(null);
  const observeStartRef = useRef<number>(0);
  const observeEndRef = useRef<number>(0);
  const [variant] = useState<"A" | "B">(() => Math.random() < 0.5 ? "A" : "B");
  const timerRef = useRef<ReturnType<typeof setTimeout> | null>(null);
  const intervalRef = useRef<ReturnType<typeof setInterval> | null>(null);
  const stim = STIMULI[stimIdx];
  const totalStimuli = STIMULI.length;
  function clearObserveTimers() {
    if (timerRef.current) { clearTimeout(timerRef.current); timerRef.current = null; }
    if (intervalRef.current) { clearInterval(intervalRef.current); intervalRef.current = null; }
  }
  function advanceObserve() {
    observeEndRef.current = Date.now();
    clearObserveTimers();
    setCountdown(null);
    setStep("react-immediate");
  }
  function startObserve() {
    observeStartRef.current = Date.now();
    observeEndRef.current = 0;
    setStep("observe");
    setCountdown(35);
    intervalRef.current = setInterval(() => {
      setCountdown((c) => {
        if (c === null || c <= 1) { clearInterval(intervalRef.current!); intervalRef.current = null; return null; }
        return c - 1;
      });
    }, 1000);
    timerRef.current = setTimeout(() => {
      intervalRef.current && clearInterval(intervalRef.current);
      intervalRef.current = null;
      observeEndRef.current = Date.now();
      setCountdown(null);
      setStep("react-immediate");
    }, 35000);
  }
  function pickReaction(r: ReactionLevel) {
    setCurrent((c) => ({ ...c, reaction: r }));
    setStep("react-association");
  }
  function pickAssociation(a: AssociationLevel) {
    setCurrent((c) => ({ ...c, association: a }));
    setStep("react-scales");
  }
  function confirmScales() {
    const now = Date.now();
    const reactionTimeMs = now - observeStartRef.current;
    const observeTimeMs = observeEndRef.current > 0
      ? observeEndRef.current - observeStartRef.current
      : reactionTimeMs;
    const responseType: ResponseType = observeTimeMs < 8000 ? "instinctive" : "reflective";
    const completed: StimulusResponse = {
      ...current,
      id: stim.id, label: stim.label, variant,
      reactionTimeMs, observeTimeMs, responseType,
    };
    const newResponses = [...responses, completed];
    setResponses(newResponses);
    if (stimIdx < totalStimuli - 1) {
      setCurrent(blankResponse());
      setStimIdx((i) => i + 1);
      setStep("transition");
      setTimeout(() => startObserve(), 800);
    } else {
      submitAll(newResponses);
    }
  }
  async function submitAll(allResponses: StimulusResponse[]) {
    if (!connected || !publicKey) { setError("Wallet not connected."); setStep("error"); return; }
    setStep("processing");
    try {
      const iss = computeISS(allResponses);
      const timestamp = Date.now();
      const payload = {
        protocol: "imprint-v2",
        timestamp,
        variant,
        responses: allResponses.map((r) => ({
          stimulus: r.id, variant: r.variant, reaction: r.reaction, association: r.association,
          scales: { anxiety: r.anxiety, sadness: r.sadness, fear: r.fear, connection: r.connection },
          reactionTimeMs: r.reactionTimeMs, observeTimeMs: r.observeTimeMs, responseType: r.responseType,
        })),
        iss: {
          score: iss.score, attachmentProfile: iss.attachmentProfile,
          emotionalIntensity: iss.emotionalIntensity, associationRate: iss.associationRate,
          avgObserveTimeMs: iss.avgObserveTimeMs, emotionalDelta: iss.emotionalDelta,
          emotionalVariance: iss.emotionalVariance, dominantTrigger: iss.dominantTrigger,
          overallResponseType: iss.overallResponseType,
        },
      };
      setProgress("Calculando hash dos dados...");
      const hash = generateHash(payload);
      setProgress("Enviando payload para IPFS...");
      const uri = await uploadToIPFS(payload);
      setProgress("Preparando metadados do NFT...");
      const nftMetadata = buildNftMetadata(iss, uri, variant);
      const nftMetadataUri = await uploadNftMetadata(nftMetadata);
      setProgress("Mintando NFT e ancorando hash on-chain...");
      let nftMint: string | undefined;
      let nftTx: string | undefined;
      let signature = "N/A";
      try {
        const nftRes = await fetch("/api/nft/mint", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            walletAddress: publicKey.toBase58(),
            metadataUri: nftMetadataUri,
            nftName: `ImprintID — ${iss.attachmentLabel}`,
            hash, uri, iss: iss.score,
            attachmentProfile: iss.attachmentProfile,
            variant, timestamp,
          }),
        });
        if (nftRes.ok) {
          const data = await nftRes.json() as {
            mint?: string; txSignature?: string; memoSignature?: string;
          };
          nftMint = data.mint;
          nftTx = data.txSignature;
          signature = data.memoSignature ?? "N/A";
        } else {
          console.warn("NFT/anchor API returned", nftRes.status);
        }
      } catch (nftErr: unknown) {
        console.warn("NFT/anchor call failed (non-fatal):", nftErr);
      }
      setStep("done");
      setTimeout(() => {
        onFinish({ hash, uri, signature, responses: allResponses, iss, timestamp, nftMint, nftMetadataUri, nftTx });
      }, 1600);
    } catch (err: unknown) {
      setError((err as { message?: string })?.message ?? "Falha no processamento.");
      setStep("error");
    }
  }
  return (
    <div className="min-h-screen bg-[#080808] text-white flex flex-col">
      <div className="flex items-center justify-between px-6 py-5 border-b border-white/8">
        <button onClick={goBack} className="flex items-center gap-2 text-sm text-white/40 hover:text-white transition-colors">
          <ArrowLeft className="w-4 h-4" /> Voltar
