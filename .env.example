# Solana Configuration
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
SOLANA_CLUSTER=devnet
PROGRAM_ID=YourProgramIdHere

# Database Configuration
DATABASE_URL=postgresql://imprintid_user:imprintid_password@localhost:5432/imprintid_db
DB_HOST=localhost
DB_PORT=5432
DB_USER=imprintid_user
DB_PASSWORD=imprintid_password
DB_NAME=imprintid_db

# Server Configuration
PORT=3000
NODE_ENV=development
API_URL=http://localhost:3000

# Authentication
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRATION=24h
REFRESH_TOKEN_SECRET=your_refresh_token_secret

# Frontend
REACT_APP_API_URL=http://localhost:3000
REACT_APP_SOLANA_NETWORK=devnet
REACT_APP_RPC_ENDPOINT=https://api.devnet.solana.com

# AI/ML Configuration
AI_MODEL_PATH=./models/imprint-analyzer.onnx
ML_PROCESSING_TIMEOUT=30000
TENSORFLOW_MODEL_PATH=./models/

# Storage Configuration
STORAGE_TYPE=ipfs
IPFS_GATEWAY=https://gateway.pinata.cloud
IPFS_API_URL=http://localhost:5001
ARWEAVE_GATEWAY=https://arweave.net

# Email Service (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@imprintid.io

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Security
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100

# AWS/Cloud (if using cloud storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=imprintid-data

# Third-party APIs
ANTHROPIC_API_KEY=your_anthropic_key_for_ai
HUGGINGFACE_API_KEY=your_huggingface_key

# Deployment
VERCEL_TOKEN=your_vercel_token
GITHUB_TOKEN=your_github_token
