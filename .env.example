# ──────────────────────────────────────────────────────────────────────────────
# ImprintID — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# Session secret for the API server (min 32 chars).
# IMPORTANT: This value also deterministically derives the server's Solana
# wallet keypair. Keep it stable — changing it changes the server wallet address.
SESSION_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/imprintid

# ── Solana (optional — have sane defaults) ────────────────────────────────────

# Custom Devnet RPC endpoint. Falls back to https://api.devnet.solana.com
# Use a dedicated endpoint (QuickNode, Helius free tier) to avoid rate limits.
# VITE_SOLANA_RPC=https://api.devnet.solana.com

# Deployed Anchor program ID from Solana Playground.
# When not set, the app uses the Memo Program as fallback (no deploy needed).
# VITE_PROGRAM_ID=REPLACE_WITH_YOUR_PROGRAM_ID

# ── IPFS (optional — falls back to mock URI) ──────────────────────────────────

# web3.storage API key for real IPFS uploads.
# Without this, a mock ipfs:// URI is used (experiment still works).
# VITE_WEB3_STORAGE_KEY=your_web3_storage_key_here

# ── Server wallet (optional override) ────────────────────────────────────────

# Override the server Solana payer keypair with a pre-funded wallet.
# Format: JSON array of 64 numbers (Solana secret key format).
# Example: [1,2,3,...,64]  (generate with: solana-keygen new --outfile key.json)
# When not set, keypair is derived from SESSION_SECRET (stable across restarts).
# SOLANA_SERVER_KEYPAIR=[1,2,3,...]

# ── Server (injected automatically by the Replit proxy) ───────────────────────

# PORT and BASE_PATH are set automatically by the runtime — do not set manually.
# PORT=8080
# BASE_PATH=/
